# ── Catalyst Center connection ───────────────────────────────────────────────
CATALYST_BASE_URL=https://dnac.example.com
CATALYST_USERNAME=apiuser
CATALYST_PASSWORD=changeme
# Set to false only for lab appliances with self-signed certs
CATALYST_VERIFY_SSL=true
CATALYST_TIMEOUT=30

# ── Inventory mapping ────────────────────────────────────────────────────────
# Comma-separated Catalyst Center device families to keep.
SWITCH_FAMILIES=Switches and Hubs
# Which hierarchy level after "Global" is the region.
# Global/EMEA/Munich/Plant-A  with level 1  ->  region = EMEA
REGION_HIERARCHY_LEVEL=1
# Regex (one capture group) that pulls the 3-letter site code from a hostname.
# SSTO010CIS -> STO. The captured group is upper-cased.
SITE_CODE_REGEX=^[A-Za-z]?([A-Za-z]{3})

# ── Storage (leave default when running in the container) ────────────────────
DATABASE_URL=sqlite:////data/catalyst_rdm.db

# ── Scheduling ───────────────────────────────────────────────────────────────
# 0 disables the background scheduler (sync only via the button / API)
SYNC_INTERVAL_MINUTES=0
SYNC_ON_STARTUP=false

# ── Web UI auth (optional). Leave WEB_USERNAME empty to disable. ─────────────
WEB_USERNAME=
WEB_PASSWORD=

# ── Devolutions export ───────────────────────────────────────────────────────
SSH_CONNECTION_TYPE=SSHShell
# Top-level RDM folder the tree hangs under. Blank to import under an existing root.
EXPORT_ROOT=Webasto
EXPORT_UNSORTED_GROUP=_Review
